{
	"name": "hearth",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"engines": {
		"node": ">=22.5.0"
	},
	"scripts": {
		"dev": "node --env-file-if-exists=.env node_modules/vite/bin/vite.js dev",
		"build": "vite build",
		"preview": "node --env-file-if-exists=.env node_modules/vite/bin/vite.js preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"check:native": "node scripts/check-no-native-deps.mjs"
	},
	"devDependencies": {
		"@ledgerhq/hw-app-btc": "^11.2.1",
		"@ledgerhq/hw-transport-webhid": "^6.36.0",
		"@ledgerhq/psbtv2": "^0.5.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@trezor/connect-web": "^9.7.3",
		"@types/node": "^26.1.1",
		"@types/nodemailer": "^8.0.1",
		"@types/qrcode": "^1.5.6",
		"bbqr": "^1.2.0",
		"bitbox-api": "^0.13.0",
		"buffer": "^6.0.3",
		"qrcode": "^1.5.4",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-wasm": "^3.6.0",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@fontsource/hanken-grotesk": "^5.3.0",
		"@fontsource/jetbrains-mono": "^5.3.0",
		"@fontsource/newsreader": "^5.3.0",
		"@noble/hashes": "^2.2.0",
		"@scure/base": "^2.2.0",
		"@scure/bip32": "^2.2.0",
		"@scure/bip39": "^2.2.0",
		"@scure/btc-signer": "^2.2.0",
		"bitcoinjs-lib": "^6.1.7",
		"nodemailer": "^9.0.3",
		"nostr-tools": "^2.24.0",
		"selfsigned": "^5.5.0",
		"undici": "^8.8.0"
	}
}
