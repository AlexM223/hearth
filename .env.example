# Hearth -- local Windows dev environment.
# Copy to .env and fill in your own values. Never commit .env (see .gitignore).
# Config layer: src/lib/server/config/index.ts (DECISIONS.md §5.3, §5.4).

# Leave unset for Windows dev (auto-detected as platform "dev"). Set to
# "umbrel" only inside the Umbrel container -- docker-compose.yml sets it there.
# HEARTH_PLATFORM=umbrel

PORT=3000
# HEARTH_HTTPS_PORT=3443
# HEARTH_ORIGIN=http://localhost:3000

# Bitcoin Core RPC -- Alex's local node (txindex on).
HEARTH_CORE_RPC_HOST=127.0.0.1
HEARTH_CORE_RPC_PORT=8332
HEARTH_CORE_RPC_USER=alex
# Prefer a cookie file over a hand-typed password:
# HEARTH_CORE_RPC_COOKIE=C:/path/to/.cookie
# HEARTH_CORE_RPC_PASS=

# Fulcrum (Electrum) -- Alex's Umbrel instance, PLAINTEXT (not TLS).
HEARTH_ELECTRUM_HOST=umbrel.local
HEARTH_ELECTRUM_PORT=50002

# Data dir + DB path default to ./data and ./data/hearth.db when unset.
# HEARTH_DATA_DIR=./data
# HEARTH_DB=./data/hearth.db
# HEARTH_LOG_FILE=./data/logs/hearth.log
