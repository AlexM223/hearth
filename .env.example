# Hearth -- local dev environment.
# Copy to .env and fill in your own values. Never commit .env (see .gitignore).
# Config layer: src/lib/server/config/index.ts.
# Loaded automatically by `npm run dev`/`npm run preview` via node's
# --env-file-if-exists=.env (vite does NOT load plain, non-VITE_-prefixed
# keys into process.env on its own).

# First-run admin bootstrap -- required to log in on a fresh
# ./data/hearth.db. Umbrel supplies this as APP_PASSWORD via
# docker-compose.yml; set it yourself for local dev.
# HEARTH_ADMIN_PASSWORD=choose-a-dev-install-password

# Leave unset for local dev (auto-detected as platform "dev"). Set to
# "umbrel" only inside the Umbrel container -- docker-compose.yml sets it there.
# HEARTH_PLATFORM=umbrel

PORT=3000
# HEARTH_HTTPS_PORT=3443
# HEARTH_ORIGIN=http://localhost:3000

# Bitcoin Core RPC (txindex on).
HEARTH_CORE_RPC_HOST=127.0.0.1
HEARTH_CORE_RPC_PORT=8332
HEARTH_CORE_RPC_USER=bitcoin
# Prefer a cookie file over a hand-typed password:
# HEARTH_CORE_RPC_COOKIE=/path/to/.cookie
# HEARTH_CORE_RPC_PASS=

# Fulcrum / any Electrum server -- PLAINTEXT (not TLS).
HEARTH_ELECTRUM_HOST=127.0.0.1
HEARTH_ELECTRUM_PORT=50002

# Data dir + DB path default to ./data and ./data/hearth.db when unset.
# HEARTH_DATA_DIR=./data
# HEARTH_DB=./data/hearth.db
# HEARTH_LOG_FILE=./data/logs/hearth.log
